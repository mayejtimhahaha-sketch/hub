-- ระบบลาก GUI
local dragging = false
local dragInput
local dragStart
local startPos

local function update(input)
	local delta = input.Position - dragStart
	Frame.Position = UDim2.new(
		startPos.X.Scale,
		startPos.X.Offset + delta.X,
		startPos.Y.Scale,
		startPos.Y.Offset + delta.Y
	)
end

Frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = Frame.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

Frame.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input == dragInput then
		update(input)
	end
end)

-- ===================== ฟังก์ชันช่วย =====================
local function getClosestPlayer()
	local closest
	local distance = math.huge
	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
	for _,v in pairs(Players:GetPlayers()) do
		if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
			local dist = (char.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
			if dist < distance then
				distance = dist
				closest = v
			end
		end
	end
	return closest
end

-- ===================== กระสุนสั่งตาย =====================
local killActive = false
Btn1.MouseButton1Click:Connect(function()
	killActive = not killActive
	if killActive then
		Btn1.BackgroundColor3 = Color3.fromRGB(255,50,50)
		task.spawn(function()
			while killActive do
				local char = player.Character
				local target = getClosestPlayer()
				if char and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
					local pos = target.Character.HumanoidRootPart.Position
					for _,tool in ipairs(player.Backpack:GetChildren()) do
						if tool:IsA("Tool") and tool:FindFirstChild("shot") then
							tool.Parent = char
							tool.shot:FireServer(pos)
							tool.shot:FireServer(pos)
							tool.Parent = player.Backpack
						end
					end
				end
				task.wait(0.005)
			end
		end)
	else
		Btn1.BackgroundColor3 = Color3.fromRGB(80,80,80)
	end
end)

