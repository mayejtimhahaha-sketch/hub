-- kill script
local enabled = false

local function getClosestPlayer()
	local closest
	local distance = math.huge
	local myChar = player.Character

	if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then
		return nil
	end

	for _,v in pairs(Players:GetPlayers()) do
		if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
			local dist = (myChar.HumanoidRootPart.Position - v.Character.HumanoidRootPart.Position).Magnitude
			if dist < distance then
				distance = dist
				closest = v
			end
		end
	end

	return closest
end

task.spawn(function()
	while true do
		task.wait(0.005)

		if enabled then
			local char = player.Character
			local target = getClosestPlayer()

			if char and target and target.Character then
				local pos = target.Character.HumanoidRootPart.Position

				for _,tool in ipairs(player.Backpack:GetChildren()) do
					if tool:IsA("Tool") and tool:FindFirstChild("shot") then
						tool.Parent = char
						tool.shot:FireServer(pos)
						tool.shot:FireServer(pos)
						tool.Parent = player.Backpack
					end
				end
			end
		end
	end
end)

killbutton.MouseButton1Click:Connect(function()
	enabled = not enabled

	if enabled then
		killbutton.Text = "กระสุนสั่งตาย : ปิด"
	else
		killbutton.Text = "กระสุนสั่งตาย : เปิด"
	end
end)
